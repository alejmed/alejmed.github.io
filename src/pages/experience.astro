---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { jobs } from '../data/experience';
---

<Layout title="Experience — Alejandro Blanco">
  <div class="container page-content">
    <PageHeader title="Experience" subtitle="4+ years building consumer products at scale." />

    <div class="timeline">
      {
        jobs.map((job) => (
          <div class="job fade-in">
            <div class="job-header">
              <div>
                <h2 class="company">{job.company}</h2>
                <p class="location text-muted">{job.location}</p>
              </div>
            </div>

            {job.roles.map((role) => (
              <div class="role">
                <div class="role-meta">
                  <span class="role-title">{role.title}</span>
                  <span class="role-period text-muted">{role.period}</span>
                </div>
                <ul class="bullets">
                  {role.bullets.map((b) => (
                    <li set:html={b} />
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .job {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    transition: border-color 0.2s;
  }

  .job:hover {
    border-color: color-mix(in srgb, var(--accent) 25%, var(--border));
  }

  .job-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .company {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .location {
    font-size: 0.85rem;
    margin-top: 0.2rem;
  }

  .role {
    margin-top: 1.25rem;
  }

  .role + .role {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .role-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
    margin-bottom: 1rem;
  }

  .role-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--accent);
  }

  .role-period {
    font-size: 0.82rem;
  }

  .bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .bullets li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.925rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .bullets li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 1rem;
    line-height: 1.7;
  }

  .bullets li :global(strong) {
    color: var(--text);
    font-weight: 500;
  }
</style>
