---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Education — Alejandro Blanco">
  <div class="container page-content">

    <header class="page-heading fade-in">
      <h1>Education</h1>
    </header>

    <div class="edu-card card fade-in">
      <div class="edu-inner">
        <div class="edu-main">
          <p class="section-label">Bachelor of Science</p>
          <h2 class="school">California State University,<br class="mobile-br"/> Sacramento</h2>
          <p class="degree">Computer Science</p>
        </div>
        <div class="edu-meta">
          <span class="year">2021</span>
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .edu-card { max-width: 620px; padding: 2.25rem 2.5rem; }

  .edu-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .school {
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 0.4rem;
  }

  .degree {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .year {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.03em;
    opacity: 0.8;
    white-space: nowrap;
  }

  .mobile-br { display: none; }

  @media (max-width: 480px) {
    .edu-inner { flex-direction: column; gap: 1rem; }
    .mobile-br { display: block; }
    .edu-card { padding: 1.5rem; }
  }
</style>
