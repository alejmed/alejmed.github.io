---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Education — Alejandro Blanco">
  <div class="container page-content">
    <PageHeader title="Education" />

    <div class="edu-card card fade-in">
      <div class="edu-inner">
        <div>
          <p class="section-label">Bachelor of Science</p>
          <h2 class="school">California State University, Sacramento</h2>
          <p class="degree text-muted">Computer Science</p>
        </div>
        <span class="year">2021</span>
      </div>
    </div>
  </div>
</Layout>

<style>
  .edu-card {
    max-width: 620px;
    padding: 2.25rem 2.5rem;
  }

  .edu-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .school {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0.5rem 0 0.4rem;
  }

  .degree {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .year {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.03em;
    opacity: 0.8;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .edu-card {
      padding: 1.5rem;
    }
    .edu-inner {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
