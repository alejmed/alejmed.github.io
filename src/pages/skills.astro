---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { skillGroups } from '../data/skills';
---

<Layout title="Skills — Alejandro Blanco">
  <div class="container page-content">
    <PageHeader title="Skills" subtitle="Technologies and tools I work with day-to-day." />

    <div class="skills-grid">
      {
        skillGroups.map((group) => (
          <div class="skill-card card fade-in">
            <p class="section-label">{group.category}</p>
            <div class="pill-group">
              {group.skills.map((s) => (
                <span class="pill">{s}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .skill-card {
    padding: 1.5rem 1.75rem;
  }

  .skill-card .section-label {
    margin-bottom: 1rem;
  }

  .pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (max-width: 480px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
