---
import Layout from '../layouts/Layout.astro';

const skillGroups = [
  {
    category: 'Mobile',
    skills: ['Kotlin', 'Jetpack Compose', 'Android SDK', 'MVVM', 'Dagger', 'Swift'],
  },
  {
    category: 'Testing',
    skills: ['JUnit', 'MockK', 'Espresso', 'Automation Testing'],
  },
  {
    category: 'Observability',
    skills: ['Firebase', 'Amplitude', 'DataDog', 'Optimizely'],
  },
  {
    category: 'CI / CD',
    skills: ['Jenkins', 'Git', 'GitHub Actions'],
  },
  {
    category: 'AI Tooling',
    skills: ['Claude', 'Cursor', 'Codex'],
  },
];
---

<Layout title="Skills — Alejandro Blanco">
  <div class="container page-content">

    <header class="page-heading fade-in">
      <h1>Skills</h1>
      <p>Technologies and tools I work with day-to-day.</p>
    </header>

    <div class="skills-grid">
      {skillGroups.map((group) => (
        <div class="skill-card card fade-in">
          <p class="section-label">{group.category}</p>
          <div class="pill-group">
            {group.skills.map(s => <span class="pill">{s}</span>)}
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .skill-card { padding: 1.5rem 1.75rem; }

  .skill-card .section-label { margin-bottom: 1rem; }

  .pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (max-width: 480px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
