---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { projects } from '../data/projects';

const checkIcon = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
const githubIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`;
---

<Layout title="Projects | Alejandro Blanco">
  <div class="container page-content">
    <PageHeader title="Projects" subtitle="Work I've led or owned end-to-end." />

    <div class="projects-list">
      {
        projects.map((p) => (
          <article class="project-card fade-in">

            {/* Visual panel — only shown when real screenshots exist */}
            {p.screenshots.length > 0 && (
              <div class="visual-panel">
                <ScreenshotGallery screenshots={p.screenshots} alt={p.name} />
              </div>
            )}

            {/* Content */}
            <div class="content-panel">
              <div class="content-top">
                <p class="project-meta text-muted">{p.company} · {p.role}</p>
                <h2 class="project-name">{p.name}</h2>
                <div class="tag-row">
                  {p.tags.map((t) => <span class="pill">{t}</span>)}
                </div>
              </div>

              <p class="project-desc">{p.description}</p>

              <div class="card-footer">
                <ul class="highlights">
                  {p.highlights.map((h) => (
                    <li>
                      <Fragment set:html={checkIcon} />
                      {h}
                    </li>
                  ))}
                </ul>
                {p.repoUrl && (
                  <a href={p.repoUrl} target="_blank" rel="noopener" class="repo-link">
                    <Fragment set:html={githubIcon} />
                    View source
                  </a>
                )}
              </div>
            </div>

          </article>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ─── Card ─── */
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
  }

  html.dark .project-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  }

  /* ─── Visual panel ─── */
  .visual-panel {
    position: relative;
    height: 260px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .visual-panel > :global(*) {
    position: absolute;
    inset: 0;
  }

  /* ─── Content panel ─── */
  .content-panel {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .content-top {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-meta {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .project-name {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.1rem;
  }

  .project-desc {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
  }

  .highlights li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
  }

  .highlights li :global(svg) {
    stroke: var(--accent);
    flex-shrink: 0;
  }

  .repo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    padding: 0.25rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    transition-property: background-color, border-color, scale;
    transition-duration: 0.15s;
    transition-timing-function: ease-out;
    flex-shrink: 0;
  }

  .repo-link:hover {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-decoration: none;
  }

  .repo-link:active {
    scale: 0.96;
  }

  @media (max-width: 600px) {
    .visual-panel { height: 200px; }
    .content-panel { padding: 1.25rem; }
  }
</style>
