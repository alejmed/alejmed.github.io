---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { projects } from '../data/projects';

const checkIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<Layout title="Projects — Alejandro Blanco">
  <div class="container page-content">
    <PageHeader title="Projects" subtitle="Work I've led or owned end-to-end." />

    <div class="projects-list">
      {
        projects.map((p) => (
          <article class="project-card card fade-in">
            <div class="project-top">
              <div>
                <p class="project-company text-muted">
                  {p.company} — {p.role}
                </p>
                <h2 class="project-name">{p.name}</h2>
              </div>
              <div class="tag-row">
                {p.tags.map((t) => (
                  <span class="pill">{t}</span>
                ))}
              </div>
            </div>

            <p class="project-desc">{p.description}</p>

            <ul class="highlights">
              {p.highlights.map((h) => (
                <li>
                  <Fragment set:html={checkIcon} />
                  {h}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-card {
    padding: 2rem;
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .project-company {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.3rem;
  }

  .project-name {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: flex-end;
  }

  .project-desc {
    font-size: 0.925rem;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1.5rem;
  }

  .highlights li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.825rem;
    font-weight: 500;
    color: var(--accent);
  }

  .highlights li :global(svg) {
    stroke: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .project-top {
      flex-direction: column;
      gap: 0.75rem;
    }
    .tag-row {
      justify-content: flex-start;
    }
  }
</style>
