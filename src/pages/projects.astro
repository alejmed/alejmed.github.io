---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { projects } from '../data/projects';

const checkIcon = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<Layout title="Projects | Alejandro Blanco">
  <div class="container page-content">
    <PageHeader title="Projects" subtitle="Work I've led or owned end-to-end." />

    <div class="projects-list">
      {
        projects.map((p) => (
          <article class="project-card fade-in">

            {/* Visual panel — only shown when real screenshots exist */}
            {p.screenshots.length > 0 && (
              <div class="visual-panel">
                <ScreenshotGallery screenshots={p.screenshots} alt={p.name} />
              </div>
            )}

            {/* Content */}
            <div class="content-panel">
              <div class="content-top">
                <p class="project-meta text-muted">{p.company} · {p.role}</p>
                <h2 class="project-name">{p.name}</h2>
                <div class="tag-row">
                  {p.tags.map((t) => <span class="pill">{t}</span>)}
                </div>
              </div>

              <p class="project-desc">{p.description}</p>

              <ul class="highlights">
                {p.highlights.map((h) => (
                  <li>
                    <Fragment set:html={checkIcon} />
                    {h}
                  </li>
                ))}
              </ul>
            </div>

          </article>
        ))
      }
    </div>
  </div>
</Layout>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ─── Card ─── */
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
  }

  html.dark .project-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
  }

  /* ─── Visual panel ─── */
  .visual-panel {
    position: relative;
    height: 260px;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .visual-panel > :global(*) {
    position: absolute;
    inset: 0;
  }

  /* ─── Content panel ─── */
  .content-panel {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .content-top {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-meta {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .project-name {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.1rem;
  }

  .project-desc {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
  }

  .highlights li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
  }

  .highlights li :global(svg) {
    stroke: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .visual-panel { height: 200px; }
    .content-panel { padding: 1.25rem; }
  }
</style>
