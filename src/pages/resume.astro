---
import { jobs } from '../data/experience';
import { skillGroups } from '../data/skills';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alejandro Blanco | Resume</title>
    <script is:inline>
      (function () {
        const stored = sessionStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <div class="resume-wrap">
      <!-- Screen-only controls -->
      <div class="controls">
        <a href="/" class="back-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Back
        </a>
        <a href="/resume.pdf" download="Alejandro_Blanco_Resume.pdf" class="print-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download PDF
        </a>
      </div>

      <!-- Resume document -->
      <article class="resume">

        <!-- Header -->
        <header class="resume-header">
          <div>
            <h1 class="resume-name">Alejandro Blanco</h1>
            <p class="resume-title">Senior Mobile Software Engineer</p>
          </div>
          <div class="resume-contact">
            <a href="mailto:alejmedina@duck.com">alejmedina@duck.com</a>
            <span class="dot">·</span>
            <a href="https://github.com/alejmed" target="_blank" rel="noopener">github.com/alejmed</a>
            <span class="dot">·</span>
            <a href="https://alejmed.github.io" target="_blank" rel="noopener">alejmed.github.io</a>
            <span class="dot">·</span>
            <span>Remote</span>
          </div>
        </header>

        <div class="resume-divider"></div>

        <!-- Experience -->
        <section class="resume-section">
          <h2 class="section-heading">Experience</h2>
          <div class="jobs">
            {jobs.map((job) => (
              <div class="job">
                <div class="job-header">
                  <div>
                    <span class="job-company">{job.company}</span>
                    <span class="job-location">{job.location}</span>
                  </div>
                  <span class="job-descriptor">{job.descriptor}</span>
                </div>
                {job.roles.map((role) => (
                  <div class="role">
                    <div class="role-header">
                      <span class="role-title">{role.title}</span>
                      <span class="role-period">{role.period}</span>
                    </div>
                    <ul class="bullets">
                      {role.bullets.map((b) => (
                        <li><span set:html={b} /></li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </section>

        <div class="resume-divider"></div>

        <!-- Skills -->
        <section class="resume-section">
          <h2 class="section-heading">Skills</h2>
          <div class="skills-grid">
            {skillGroups.map((g) => (
              <div class="skill-row">
                <span class="skill-category">{g.category}</span>
                <span class="skill-list">{g.skills.join(' · ')}</span>
              </div>
            ))}
          </div>
        </section>

        <div class="resume-divider"></div>

        <!-- Education -->
        <section class="resume-section">
          <h2 class="section-heading">Education</h2>
          <div class="edu-row">
            <div>
              <p class="edu-school">California State University, Sacramento</p>
              <p class="edu-degree">B.S. Computer Science</p>
            </div>
            <span class="edu-year">2021</span>
          </div>
        </section>

      </article>
    </div>
  </body>
</html>

<style>
  body {
    background: var(--bg);
  }

  .resume-wrap {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  /* ─── Screen controls ─── */
  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--text); text-decoration: none; }

  .print-btn, a.print-btn {
    text-decoration: none;
  }
  .print-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    border-radius: 6px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    transition-property: background-color, border-color, scale;
    transition-duration: 0.15s;
    transition-timing-function: ease-out;
  }
  .print-btn:hover {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .print-btn:active { scale: 0.96; }

  /* ─── Document ─── */
  .resume {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 3rem 3.5rem;
    box-shadow: var(--shadow);
  }

  /* ─── Header ─── */
  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .resume-name {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
    line-height: 1;
    margin-bottom: 0.35rem;
  }

  .resume-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  .resume-contact {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: right;
  }

  .resume-contact a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .resume-contact a:hover { color: var(--accent); }

  .dot { opacity: 0.5; }

  /* ─── Divider ─── */
  .resume-divider {
    height: 1px;
    background: var(--border);
    margin: 1.75rem 0;
  }

  /* ─── Section ─── */
  .resume-section { display: flex; flex-direction: column; gap: 1rem; }

  .section-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ─── Experience ─── */
  .jobs { display: flex; flex-direction: column; gap: 1.5rem; }

  .job { display: flex; flex-direction: column; gap: 0.6rem; }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .job-company {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .job-location {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }

  .job-descriptor {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .role { display: flex; flex-direction: column; gap: 0.5rem; }

  .role-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .role-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
  }

  .role-period {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-left: 0.75rem;
  }

  .bullets li {
    font-size: 0.83rem;
    line-height: 1.6;
    color: var(--text-muted);
    position: relative;
  }

  .bullets li::before {
    content: '·';
    position: absolute;
    left: -0.75rem;
    color: var(--accent);
    font-weight: 700;
  }

  .bullets li :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  /* ─── Skills ─── */
  .skills-grid { display: flex; flex-direction: column; gap: 0.45rem; }

  .skill-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .skill-category {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
  }

  .skill-list {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ─── Education ─── */
  .edu-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .edu-school {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .edu-degree {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  .edu-year {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.03em;
    opacity: 0.8;
  }

  /* ─── Print ─── */
  @media print {
    @page { margin: 1.5cm 1.8cm; }

    body { background: white !important; }

    .controls { display: none; }

    .resume-wrap { padding: 0; max-width: 100%; }

    .resume {
      border: none;
      box-shadow: none;
      border-radius: 0;
      padding: 0;
      background: white !important;
    }

    :root {
      --bg: white;
      --surface: white;
      --text: #1c1a16;
      --text-muted: #5a5048;
      --accent: #2c5429;
      --border: #d0c9be;
    }

    .resume-contact a { color: var(--text-muted) !important; }
  }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .resume { padding: 1.75rem 1.5rem; }
    .resume-header { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .resume-contact { text-align: left; }
    .job-header { flex-direction: column; gap: 0.1rem; }
    .skill-row { grid-template-columns: 90px 1fr; }
  }
</style>
