---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Alejandro Blanco | Software Engineer">
  <div class="container page-content">
    <section class="hero">
      <p class="section-label fade-in" style="transition-delay: 0ms">Senior Mobile Software Engineer</p>
      <h1 class="hero-name fade-in" style="transition-delay: 100ms">Alejandro<br />Blanco</h1>
      <p class="hero-bio fade-in" style="transition-delay: 200ms">
        I build consumer mobile products that reach millions of people. Specializing in Android with
        deep roots in cross-platform mobile, I take full ownership from architecture and API
        contracts to the final screen users touch. Currently at EarnIn, where I pioneered the
        company's AI-assisted mobile development workflow and led the cross-platform launch of the
        EarnIn Card, driving 600K+ waitlist signups and 1M+ Live Pay transactions.
      </p>
      <div class="hero-links fade-in" style="transition-delay: 300ms">
        <a href="https://github.com/alejmed" target="_blank" rel="noopener" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
            ></path></svg
          >
          GitHub
        </a>
        <a href="mailto:alejmedina@duck.com" class="btn btn-outline">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path><polyline points="22,6 12,13 2,6"></polyline></svg
          >
          alejmedina@duck.com
        </a>
        <a href="/resume.pdf" download="Alejandro_Blanco_Resume.pdf" class="btn btn-outline">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download Resume
        </a>
      </div>
    </section>

    <div class="divider"></div>

    <section class="currently fade-in">
      <p class="section-label">Currently</p>
      <div class="currently-grid">
        <div class="currently-item">
          <span class="currently-dot"></span>
          <div>
            <p class="currently-role">Senior Software Engineer</p>
            <p class="text-muted" style="font-size: 0.875rem;">
              EarnIn · Palo Alto, CA · Remote
            </p>
          </div>
        </div>
        <div class="currently-item">
          <span class="currently-dot dot-side"></span>
          <div>
            <p class="currently-role">Android &amp; iOS</p>
            <p class="text-muted" style="font-size: 0.875rem;">
              Cross-platform mobile, Kotlin &middot; Swift
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="snapshot fade-in">
      <p class="section-label">By the numbers</p>
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-num">4+</span>
          <span class="stat-label">Years in mobile</span>
        </div>
        <div class="stat">
          <span class="stat-num">600K+</span>
          <span class="stat-label">EarnIn Card waitlist</span>
        </div>
        <div class="stat">
          <span class="stat-num">1M+</span>
          <span class="stat-label">Live Pay transactions</span>
        </div>
        <div class="stat">
          <span class="stat-num">7</span>
          <span class="stat-label">Engineers led</span>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .hero {
    margin-bottom: 0;
  }

  .hero-name {
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1.5rem;
  }

  .hero-bio {
    max-width: 600px;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Currently */
  .currently-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .currently-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .currently-dot {
    margin-top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
    animation: pulse 2s infinite;
  }

  .dot-side {
    background: var(--text-muted);
    box-shadow: none;
    animation: none;
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent) 8%, transparent);
    }
  }

  .currently-role {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
