---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Alejandro Blanco"
  description="Get in touch with Alejandro Blanco — Senior Mobile Software Engineer."
>
  <div class="container page-content">
    <header class="page-heading fade-in">
      <h1>Get in Touch</h1>
      <p>Open to conversations about interesting problems and roles.</p>
    </header>

    <div class="contact-layout">
      <div class="contact-links fade-in">
        <p class="section-label">Direct</p>
        <a href="mailto:alejmedina@duck.com" class="contact-link">
          <span class="link-icon">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
          </span>
          <div>
            <span class="link-label">Email</span>
            <span class="link-value">alejmedina@duck.com</span>
          </div>
        </a>
        <a href="https://github.com/alejmed" target="_blank" rel="noopener" class="contact-link">
          <span class="link-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
          </span>
          <div>
            <span class="link-label">GitHub</span>
            <span class="link-value">github.com/alejmed</span>
          </div>
        </a>
      </div>

      <div class="contact-form-wrap fade-in">
        <p class="section-label">Send a message</p>
        <form
          id="contactForm"
          class="contact-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
        >
          <div class="field">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="field">
            <label for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="What's on your mind?"
              required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" id="submitBtn">
            Send Message
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
            >
          </button>
          <p id="formMsg" class="form-msg" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<!--
  SETUP: Create a free Formspree account at formspree.io,
  create a new form, and replace YOUR_FORM_ID in the form action above.
  Free tier = 50 submissions/month.
-->

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement;
  const msg = document.getElementById('formMsg') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        msg.textContent = "Message sent — I'll get back to you soon.";
        msg.className = 'form-msg success';
        btn.textContent = 'Sent!';
      } else {
        throw new Error();
      }
    } catch {
      msg.textContent = 'Something went wrong. Email me directly at alejmedina@duck.com';
      msg.className = 'form-msg error';
      btn.disabled = false;
      btn.textContent = 'Try again';
    }
  });
</script>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Contact links */
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .contact-links .section-label {
    margin-bottom: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    text-decoration: none;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
    box-shadow: var(--shadow);
  }
  .contact-link:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .link-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .link-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .link-value {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
  }

  /* Form */
  .contact-form-wrap .section-label {
    margin-bottom: 1.25rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .field input,
  .field textarea {
    font-family: 'Inter', sans-serif;
    font-size: 0.925rem;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.7rem 0.875rem;
    outline: none;
    transition: border-color 0.15s;
    resize: vertical;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--accent);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .btn[type='submit'] {
    align-self: flex-start;
    margin-top: 0.25rem;
  }

  .form-msg {
    font-size: 0.85rem;
    min-height: 1.2em;
  }
  .form-msg.success {
    color: #16a34a;
  }
  .form-msg.error {
    color: #dc2626;
  }

  @media (max-width: 660px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
