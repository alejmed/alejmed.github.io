---
const transactions = [
  { icon: '🏦', label: 'Direct Deposit', amount: '+$2,150.00', date: 'May 15', positive: true },
  { icon: '💳', label: 'EarnIn Card', amount: '-$42.99', date: 'May 14', positive: false },
  { icon: '💸', label: 'Cash Out', amount: '+$200.00', date: 'May 13', positive: true },
  { icon: '🛒', label: 'EarnIn Card', amount: '-$18.45', date: 'May 12', positive: false },
];
---

<div class="aa-preview" aria-hidden="true">
  <!-- Header -->
  <div class="aa-header">
    <div class="aa-header-left">
      <p class="aa-header-label">Account Activity</p>
      <p class="aa-header-balance">$3,241.88</p>
    </div>
    <button class="aa-filter" aria-hidden="true">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" y1="6" x2="20" y2="6"></line><line x1="8" y1="12" x2="16" y2="12"></line><line
          x1="12"
          y1="18"
          x2="12"
          y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Month group -->
  <p class="aa-month">MAY 2024</p>

  <!-- Transactions -->
  <div class="aa-list">
    {
      transactions.map((tx) => (
        <div class="aa-row">
          <div class="aa-icon">{tx.icon}</div>
          <div class="aa-details">
            <p class="aa-label">{tx.label}</p>
            <p class="aa-date">{tx.date}</p>
          </div>
          <p class={`aa-amount ${tx.positive ? 'positive' : 'negative'}`}>{tx.amount}</p>
        </div>
      ))
    }
  </div>
</div>

<style>
  .aa-preview {
    width: 100%;
    height: 100%;
    background: #f8fafc;
    display: flex;
    flex-direction: column;
    padding: 1rem 1.1rem 0.5rem;
    font-family: -apple-system, 'Inter', sans-serif;
    overflow: hidden;
  }

  html.dark .aa-preview {
    background: #111827;
  }

  /* Header */
  .aa-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.875rem;
  }

  .aa-header-label {
    font-size: 0.6rem;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.15rem;
  }

  html.dark .aa-header-label {
    color: #64748b;
  }

  .aa-header-balance {
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.03em;
  }

  html.dark .aa-header-balance {
    color: #f1f5f9;
  }

  .aa-filter {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 0.3rem;
    color: #64748b;
    cursor: default;
    display: flex;
    align-items: center;
  }

  html.dark .aa-filter {
    background: #1e293b;
    border-color: #334155;
    color: #94a3b8;
  }

  /* Month label */
  .aa-month {
    font-size: 0.55rem;
    font-weight: 700;
    color: #94a3b8;
    letter-spacing: 0.12em;
    margin-bottom: 0.35rem;
  }

  /* Transaction list */
  .aa-list {
    display: flex;
    flex-direction: column;
  }

  .aa-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f1f5f9;
  }

  html.dark .aa-row {
    border-color: #1e293b;
  }

  .aa-row:last-child {
    border-bottom: none;
  }

  .aa-icon {
    font-size: 1rem;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
    border-radius: 8px;
    flex-shrink: 0;
  }

  html.dark .aa-icon {
    background: #1e293b;
  }

  .aa-details {
    flex: 1;
    min-width: 0;
  }

  .aa-label {
    font-size: 0.65rem;
    font-weight: 600;
    color: #0f172a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  html.dark .aa-label {
    color: #f1f5f9;
  }

  .aa-date {
    font-size: 0.55rem;
    color: #94a3b8;
    margin-top: 0.05rem;
  }

  .aa-amount {
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .aa-amount.positive {
    color: #16a34a;
  }
  .aa-amount.negative {
    color: #0f172a;
  }
  html.dark .aa-amount.negative {
    color: #cbd5e1;
  }
</style>
