---

---

<div class="aw-preview" aria-hidden="true">
  <!-- Window chrome -->
  <div class="aw-chrome">
    <div class="aw-dots">
      <span class="aw-dot dot-red"></span>
      <span class="aw-dot dot-yellow"></span>
      <span class="aw-dot dot-green"></span>
    </div>
    <span class="aw-title">amadeus · mobile-dev</span>
  </div>

  <!-- Terminal body -->
  <div class="aw-body">
    <p class="aw-prompt">
      <span class="aw-dir">~/earninapp/mobile</span>
      <span class="aw-caret">$</span> amadeus run
    </p>

    <div class="aw-output">
      <p class="aw-line">
        <span class="aw-check">✓</span>
        <span class="aw-key">Context</span>
        <span class="aw-val">1,247 tokens loaded</span>
      </p>
      <p class="aw-line">
        <span class="aw-check">✓</span>
        <span class="aw-key">Memory </span>
        <span class="aw-val">session restored</span>
      </p>
      <p class="aw-line">
        <span class="aw-check">✓</span>
        <span class="aw-key">Tests </span>
        <span class="aw-val">142 / 142 passing</span>
      </p>
      <p class="aw-line">
        <span class="aw-check">✓</span>
        <span class="aw-key">Lint </span>
        <span class="aw-val">clean</span>
      </p>
      <p class="aw-line aw-gap">
        <span class="aw-arrow">→</span>
        <span class="aw-dim">Booting Android emulator...</span>
      </p>
      <p class="aw-line">
        <span class="aw-spin">◎</span>
        <span class="aw-dim">Pixel 7 API 34 </span><span class="aw-badge">RUNNING</span>
      </p>
      <p class="aw-line aw-gap">
        <span class="aw-arrow">→</span>
        <span class="aw-dim">Starting CI pipeline...</span>
      </p>
      <p class="aw-line">
        <span class="aw-check">✓</span>
        <span class="aw-key">Build </span>
        <span class="aw-success">SUCCESS</span><span class="aw-dim"> (2.1s)</span>
      </p>
    </div>

    <p class="aw-cursor">█</p>
  </div>
</div>

<style>
  .aw-preview {
    width: 100%;
    height: 100%;
    background: #0d1117;
    display: flex;
    flex-direction: column;
    font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
    overflow: hidden;
  }

  /* Window chrome */
  .aw-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #161b22;
    border-bottom: 1px solid #21262d;
    flex-shrink: 0;
  }

  .aw-dots {
    display: flex;
    gap: 0.3rem;
  }

  .aw-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot-red {
    background: #ff5f57;
  }
  .dot-yellow {
    background: #febc2e;
  }
  .dot-green {
    background: #28c840;
  }

  .aw-title {
    font-size: 0.6rem;
    color: #6e7681;
    letter-spacing: 0.03em;
    flex: 1;
    text-align: center;
  }

  /* Terminal body */
  .aw-body {
    padding: 0.75rem 0.875rem;
    flex: 1;
    overflow: hidden;
  }

  .aw-prompt {
    font-size: 0.62rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .aw-dir {
    color: #e8c07a;
  }
  .aw-caret {
    color: #3fb950;
    margin: 0 0.25rem;
  }

  .aw-output {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
  }

  .aw-line {
    font-size: 0.6rem;
    line-height: 1.6;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .aw-gap {
    margin-top: 0.35rem;
  }

  .aw-check {
    color: #3fb950;
    flex-shrink: 0;
  }
  .aw-arrow {
    color: #6e7681;
    flex-shrink: 0;
  }
  .aw-spin {
    color: #e8c07a;
    flex-shrink: 0;
    animation: spin-step 1.2s steps(8) infinite;
    display: inline-block;
  }

  @keyframes spin-step {
    to {
      transform: rotate(360deg);
    }
  }

  .aw-key {
    color: #6e7681;
    min-width: 4.5rem;
  }
  .aw-val {
    color: #e6edf3;
  }
  .aw-dim {
    color: #6e7681;
  }
  .aw-success {
    color: #3fb950;
    font-weight: 700;
  }

  .aw-badge {
    font-size: 0.5rem;
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
    background: rgba(63, 185, 80, 0.15);
    border: 1px solid rgba(63, 185, 80, 0.3);
    color: #3fb950;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .aw-cursor {
    font-size: 0.65rem;
    color: #3fb950;
    margin-top: 0.4rem;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
